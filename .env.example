# ── VARIABLES DE ENTORNO — EDITAR ANTES DE DESPLEGAR ──

# Contraseña del SA de SQL Server (mínimo 8 chars, mayúscula, minúscula, número y símbolo)
SA_PASSWORD=YourStrong!Passw0rd

# SMTP (para envío de correos)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_SENDER_NAME=Reservas XYZ
SMTP_EMAIL=tu-correo@gmail.com
SMTP_PASSWORD=tu-app-password

# Dominio (subdominio de Hostinger)
DOMAIN=reservas.tu-dominio.com
