@page
@model ResendEmailConfirmationModel
@{
    ViewData["Title"] = "Reenviar confirmación";
}

<div class="compute-card w-full max-w-[438px] rounded-3xl p-6 lg:p-7">
    <div class="app-auth-header">
        <div class="app-compact-heading app-compact-heading--solo">
            <h1 class="app-compact-heading-title">Reenviar confirmación</h1>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="mb-4 rounded-2xl border border-foreground/10 bg-background/80 px-4 py-3 text-sm text-muted-foreground">
            @Model.StatusMessage
        </div>
    }

    <form asp-page="./ResendEmailConfirmation" method="post" class="space-y-4">
        <div asp-validation-summary="ModelOnly" class="text-sm text-red-300"></div>

        <div>
            <label asp-for="Input.Email" class="mb-2 block text-sm text-muted-foreground">Correo electrónico</label>
            <input asp-for="Input.Email" autocomplete="username" class="compute-input" />
            <span asp-validation-for="Input.Email" class="mt-1 block text-sm text-red-300"></span>
        </div>

        <button type="submit" class="compute-button w-full">Reenviar enlace</button>

        <div class="border-t border-foreground/10 pt-5 text-center text-sm text-muted-foreground">
            <a asp-page="./Login" class="transition hover:text-foreground">Volver a iniciar sesión</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}