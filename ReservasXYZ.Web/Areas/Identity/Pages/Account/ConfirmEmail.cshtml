@page
@model ConfirmEmailModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@(Model.IsSuccess ? "Correo confirmado" : "No se pudo confirmar") - Reservas XYZ</title>
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
    <link rel="stylesheet" href="~/css/output.css">
</head>

<body class="flex min-h-screen items-center justify-center bg-background p-4 text-foreground">

    <div class="w-full max-w-sm text-center">
        @if (Model.IsSuccess)
        {
            <div class="mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-full bg-green-500/10">
                <svg class="h-8 w-8 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
            </div>
        }
        else
        {
            <div class="mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-full bg-red-500/10">
                <svg class="h-8 w-8 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </div>
        }

        <h1 class="font-display text-3xl tracking-tight">
            @(Model.IsSuccess ? "Correo confirmado" : "No se pudo confirmar")
        </h1>
        <p class="mt-3 text-sm text-muted-foreground">@Model.Message</p>

        <div class="mt-8">
            @if (Model.IsSuccess)
            {
                <a href="/?authPage=/Identity/Account/Login" class="compute-button w-full">Iniciar sesión</a>
            }
            else if (!string.IsNullOrWhiteSpace(Model.Email))
            {
                <a asp-page="./ResendEmailConfirmation" asp-route-email="@Model.Email" class="compute-button w-full">
                    Solicitar nuevo enlace
                </a>
            }
        </div>
    </div>

</body>

</html>