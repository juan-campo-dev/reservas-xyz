@model ReservasXYZ.Application.DTOs.CreateRoomDto
@{
    ViewData["Title"] = "Crear Habitación";
}

<div class="admin-form-shell">
    <div>
        <a asp-action="Index" class="admin-form-back">← Volver a habitaciones</a>
        <h2 class="admin-form-title">Nueva habitación</h2>
    </div>

    <div class="admin-form-panel">
        <div class="admin-form-section-heading">
            <p>Datos de la habitación</p>
            <p>Campos obligatorios</p>
        </div>
        <form asp-action="Create" method="post">
            <div class="admin-form-grid">
                <div class="admin-form-field">
                    <label class="admin-form-label">Alojamiento</label>
                    <select asp-for="AccommodationId" asp-items="ViewBag.Accommodations" class="admin-form-input"
                            required>
                        <option value="">Seleccionar...</option>
                    </select>
                </div>
                <div class="admin-form-field">
                    <label class="admin-form-label">Número</label>
                    <input asp-for="RoomNumber" class="admin-form-input" required />
                </div>
                <div class="admin-form-field">
                    <label class="admin-form-label">Tipo</label>
                    <select asp-for="Type" asp-items="Html.GetEnumSelectList<ReservasXYZ.Domain.Enums.RoomType>()"
                            class="admin-form-input" required></select>
                </div>
                <div class="admin-form-field">
                    <label class="admin-form-label">Capacidad máxima</label>
                    <input asp-for="MaxGuests" type="number" min="1" class="admin-form-input" required />
                </div>
                <div class="admin-form-field">
                    <label class="admin-form-label">Precio base / noche</label>
                    <input asp-for="BasePrice" type="number" step="0.01" min="0" class="admin-form-input" required />
                </div>
                <div class="admin-form-field">
                    <label class="admin-form-label">Amenidades</label>
                    <input asp-for="Amenities" placeholder="WiFi, TV, A/C..." class="admin-form-input" />
                </div>
                <div class="admin-form-field admin-form-field--wide">
                    <label class="admin-form-label">Descripción</label>
                    <textarea asp-for="Description" rows="3" class="admin-form-input"></textarea>
                </div>
            </div>
            <div class="admin-form-actions">
                <button type="submit" class="admin-form-submit">
                    <svg viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd"
                              d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z"
                              clip-rule="evenodd" />
                    </svg>
                    Guardar
                </button>
                <a asp-action="Index" class="admin-form-cancel">Cancelar</a>
            </div>
        </form>
    </div>
</div>
