@using ReservasXYZ.Domain.Enums
@{
    ViewData["Title"] = User.IsInRole("Admin") ? "Dashboard"
        : User.Identity?.IsAuthenticated == true ? "Mi portal"
        : "Fondo XYZ";
}

@if (User.Identity?.IsAuthenticated == true && User.IsInRole("Admin"))
{
    var adminModel = (DashboardDto)Model;
    var culture = CultureInfo.GetCultureInfo("es-CO");
    var availableRooms = Math.Max(adminModel.TotalRooms - adminModel.OccupiedRoomsToday, 0);
    var occupancyRate = Math.Clamp(adminModel.OccupancyRate, 0, 100);
    var occupancyWidth = FormattableString.Invariant($"{occupancyRate:0.##}%");
    var averageBookingValue = adminModel.TotalReservations > 0
        ? adminModel.TotalRevenue / adminModel.TotalReservations
        : 0;
    var confirmedRate = adminModel.TotalReservations > 0
        ? (double)adminModel.ConfirmedReservations / adminModel.TotalReservations * 100
        : 0;
    var confirmedWidth = FormattableString.Invariant($"{Math.Clamp(confirmedRate, 0, 100):0.##}%");
    var roomCellsCount = Math.Clamp(adminModel.TotalRooms, 6, 12);
    var occupiedCells = adminModel.TotalRooms > 0
        ? Math.Clamp((int)Math.Round(roomCellsCount * occupancyRate / 100), 0, roomCellsCount)
        : 0;
    var pendingCells = Math.Clamp(adminModel.PendingReservations, 0, roomCellsCount - occupiedCells);
    var chartValues = adminModel.RecentReservations
        .OrderBy(reservation => reservation.CreatedAt)
        .Select(reservation => reservation.TotalAmount)
        .ToList();
    var hasChartData = chartValues.Any();

    if (!hasChartData)
    {
        chartValues = new List<decimal> { 0m, 0m, 0m, 0m, 0m };
    }

    while (chartValues.Count < 5)
    {
        chartValues.Insert(0, 0m);
    }

    var bookingValues = hasChartData
        ? chartValues.Select((_, index) => (decimal)(index + 1)).ToList()
        : new List<decimal> { 0m, 0m, 0m, 0m, 0m };
    var chartWidth = 420m;
    var chartHeight = 180m;
    var chartPadding = 22m;
    var chartUsableWidth = chartWidth - chartPadding * 2;
    var chartUsableHeight = chartHeight - chartPadding * 2;
    Func<List<decimal>, string> buildChartPoints = values =>
    {
        var maxValue = Math.Max(1m, values.Max());
        var step = values.Count > 1 ? chartUsableWidth / (values.Count - 1) : 0m;

        return string.Join(" ", values.Select((value, index) =>
        {
            var x = values.Count == 1 ? chartWidth / 2 : chartPadding + step * index;
            var y = chartHeight - chartPadding - value / maxValue * chartUsableHeight;
            return FormattableString.Invariant($"{x:0.##},{y:0.##}");
        }));
    };
    var revenuePoints = buildChartPoints(chartValues);
    var bookingPoints = buildChartPoints(bookingValues);

    <div class="admin-dashboard">
        <div class="admin-page-header">
            <div>
                <h1 class="admin-page-header__title">Panel de control</h1>
                <p class="admin-page-header__subtitle">Operacion en vivo</p>
            </div>
            <div class="admin-page-header__metrics">
                <div class="admin-page-header__metric">
                    <span>Ingresos del mes</span>
                    <strong>@adminModel.MonthlyRevenue.ToString("C0", culture)</strong>
                </div>
                <div class="admin-page-header__separator" aria-hidden="true"></div>
                <div class="admin-page-header__metric">
                    <span>Acumulado total</span>
                    <strong>@adminModel.TotalRevenue.ToString("C0", culture)</strong>
                </div>
            </div>
        </div>

        <section class="admin-module-stats admin-module-stats--dashboard" aria-label="Indicadores principales">
            <div class="admin-module-stat admin-module-stat--blue">
                <div class="admin-module-stat__header">
                    <span class="admin-module-stat__label">Valor promedio reserva</span>
                    <div class="admin-module-stat__indicator">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="admin-module-stat__icon" aria-hidden="true"><path d="M22 12h-2.48a2 2 0 0 0-1.93 1.46l-2.35 8.36a.25.25 0 0 1-.48 0L9.24 2.18a.25.25 0 0 0-.48 0l-2.35 8.36A2 2 0 0 1 4.49 12H2"></path></svg>
                        <span class="admin-module-stat__pct">@adminModel.TotalReservations res.</span>
                    </div>
                </div>
                <strong class="admin-module-stat__value">@averageBookingValue.ToString("C0", culture)</strong>
                <div class="admin-module-stat__bar"><div class="admin-module-stat__bar-fill" style="width:100%"></div></div>
            </div>
            <div class="admin-module-stat admin-module-stat--green">
                <div class="admin-module-stat__header">
                    <span class="admin-module-stat__label">Reservas confirmadas</span>
                    <div class="admin-module-stat__indicator">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="admin-module-stat__icon" aria-hidden="true"><circle cx="12" cy="12" r="10"></circle><path d="m9 12 2 2 4-4"></path></svg>
                        <span class="admin-module-stat__pct">@confirmedWidth</span>
                    </div>
                </div>
                <strong class="admin-module-stat__value">@adminModel.ConfirmedReservations</strong>
                <div class="admin-module-stat__bar"><div class="admin-module-stat__bar-fill" style="width:@confirmedWidth"></div></div>
            </div>
            <div class="admin-module-stat admin-module-stat--orange">
                <div class="admin-module-stat__header">
                    <span class="admin-module-stat__label">Ocupacion actual</span>
                    <div class="admin-module-stat__indicator">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="admin-module-stat__icon" aria-hidden="true"><path d="M3 7v11a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V7"></path><path d="M21 7H3l2-4h14z"></path><path d="M12 11v4"></path></svg>
                        <span class="admin-module-stat__pct">@occupancyWidth</span>
                    </div>
                </div>
                <strong class="admin-module-stat__value">@adminModel.OccupiedRoomsToday / @adminModel.TotalRooms</strong>
                <div class="admin-module-stat__bar"><div class="admin-module-stat__bar-fill" style="width:@occupancyWidth"></div></div>
            </div>
            <div class="admin-module-stat admin-module-stat--purple">
                <div class="admin-module-stat__header">
                    <span class="admin-module-stat__label">Sedes activas</span>
                    <div class="admin-module-stat__indicator">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="admin-module-stat__icon" aria-hidden="true"><path d="M3 21h18"></path><path d="M5 21V7l8-4v18"></path><path d="M19 21V11l-6-4"></path></svg>
                        <span class="admin-module-stat__pct">@adminModel.TotalAccommodations aloj.</span>
                    </div>
                </div>
                <strong class="admin-module-stat__value">@adminModel.TotalSites</strong>
                <div class="admin-module-stat__bar"><div class="admin-module-stat__bar-fill" style="width:100%"></div></div>
            </div>
        </section>

        <section class="admin-dashboard-grid">
            <article class="admin-dashboard-card admin-dashboard-card--wide">
                <div class="admin-card-heading">
                    <div>
                        <p class="admin-eyebrow">Ingresos vs reservas</p>
                        <h3>Actividad reciente</h3>
                    </div>
                    <div class="admin-chart-legend" aria-hidden="true">
                        <span><i class="is-revenue"></i>Ingresos</span>
                        <span><i class="is-bookings"></i>Reservas</span>
                    </div>
                </div>
                <div class="admin-dashboard-chart" role="img" aria-label="Grafico de ingresos y reservas recientes">
                    <svg viewBox="0 0 420 180" preserveAspectRatio="none" aria-hidden="true">
                        <path d="M22 42 H398 M22 90 H398 M22 138 H398" class="admin-chart-gridline" />
                        <polyline points="@bookingPoints" class="admin-chart-line admin-chart-line--muted" />
                        <polyline points="@revenuePoints" class="admin-chart-line admin-chart-line--primary" />
                    </svg>
                </div>
            </article>

            <article class="admin-dashboard-card">
                <div class="admin-card-heading">
                    <div>
                        <p class="admin-eyebrow">Estado de habitaciones</p>
                        <h3>Hoy</h3>
                    </div>
                    <strong class="admin-room-status-total">@availableRooms libres</strong>
                </div>
                <div class="admin-room-status-grid" aria-hidden="true">
                    @for (var roomIndex = 1; roomIndex <= roomCellsCount; roomIndex++)
                    {
                        var cellClass = roomIndex <= occupiedCells
                            ? "is-occupied"
                            : roomIndex <= occupiedCells + pendingCells ? "is-pending" : "is-clear";
                        <span class="admin-room-status-cell @cellClass"></span>
                    }
                </div>
                <div class="admin-room-status-legend">
                    <span><i class="is-clear"></i>Libre</span>
                    <span><i class="is-occupied"></i>Ocupada</span>
                    <span><i class="is-pending"></i>Pendiente</span>
                </div>
            </article>
        </section>

        <section class="admin-dashboard-card admin-dashboard-table-card">
            <div class="admin-card-heading">
                <div>
                    <p class="admin-eyebrow">Reservas recientes</p>
                    <h3>Ultimos movimientos</h3>
                </div>
                <a asp-controller="Reservations" asp-action="Index" class="admin-secondary-link">Ver todas</a>
            </div>

            @if (adminModel.RecentReservations.Any())
            {
                <div class="admin-dashboard-table-wrap">
                    <table class="admin-dashboard-table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Huesped</th>
                                <th>Check-in</th>
                                <th>Estado</th>
                                <th>Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var reservation in adminModel.RecentReservations)
                            {
                                var statusClass = reservation.Status switch
                                {
                                    ReservationStatus.Pending => "reservation-status-badge--pending",
                                    ReservationStatus.Confirmed => "reservation-status-badge--confirmed",
                                    ReservationStatus.CheckedIn => "reservation-status-badge--checked-in",
                                    ReservationStatus.CheckedOut => "reservation-status-badge--checked-out",
                                    ReservationStatus.Cancelled => "reservation-status-badge--cancelled",
                                    _ => "reservation-status-badge--checked-out"
                                };

                                <tr>
                                    <td><a asp-controller="Reservations" asp-action="Details"
                                               asp-route-id="@reservation.Id">#@reservation.Id</a></td>
                                        <td>@reservation.GuestName</td>
                                        <td>@reservation.CheckIn.ToString("dd/MM/yyyy")</td>
                                        <td><span class="reservation-status-badge @statusClass">@reservation.Status.ToSpanish()</span>
                                        </td>
                                        <td>@reservation.TotalAmount.ToString("C0", culture)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            else
                {
                    <div class="admin-empty-state">No hay reservas registradas aun.</div>
                }
            </section>
        </div>
    }
else if (User.Identity?.IsAuthenticated == true)
    {
        var guestModel = (ReservasXYZ.Application.DTOs.GuestPortalDto)Model;
        var culture = CultureInfo.GetCultureInfo("es-CO");
        var todayDate = DateTime.Today;
        var tomorrowDate = todayDate.AddDays(1);
        var today = todayDate.ToString("yyyy-MM-dd");
        var tomorrow = tomorrowDate.ToString("yyyy-MM-dd");
        var upcomingReservations = guestModel.MyReservations
            .Where(reservation => reservation.Status != ReservationStatus.Cancelled && reservation.Status !=
ReservationStatus.CheckedOut)
            .OrderBy(reservation => reservation.CheckIn)
            .Take(3)
            .ToList();

        <div class="relative min-h-screen overflow-hidden bg-background text-foreground">

            <section class="guest-portal-hero">
                <div class="mx-auto max-w-[1200px] px-6 lg:px-12">
                    <div class="guest-hero-shell">
                        <img src="/images/hotel/reservations.png" alt="" class="guest-hero-image" />
                        <div class="guest-hero-overlay" aria-hidden="true"></div>
                        <div class="guest-hero-grid compute-grid" aria-hidden="true"></div>
                        <div class="guest-hero-content">
                            <div class="space-y-8">
                                <div class="guest-hero-copy" aria-live="polite">
                                    <p class="font-mono text-xs uppercase tracking-[0.28em] text-muted-foreground">Portal de
                                        reservas</p>
                                        <p class="mt-4 text-lg text-muted-foreground">Hola, @guestModel.FirstName 👋</p>
                                        <h2
                                            class="mt-2 max-w-4xl font-display text-5xl leading-[0.95] tracking-tight text-foreground md:text-7xl">
                                            <span class="guest-hero-text-default">¿A dónde quieres ir?</span>
                                            <span class="guest-hero-text-search">Elige tu alojamiento</span>
                                        </h2>
                                        <p class="mt-6 max-w-2xl text-lg text-muted-foreground">
                                            <span class="guest-hero-text-default">@guestModel.Sites.Count sedes recreativas y
                                                apartamentos en Colombia para reservar sin llamadas.</span>
                                                <span class="guest-hero-text-search">Compara las habitaciones disponibles y arma tu
                                                    reserva desde aquí.</span>
                                                </p>
                                            </div>

                                            <form asp-controller="Home" asp-action="SearchAvailability" method="post" class="sf-bar"
                                                  data-date-range-form data-availability-form data-min-date="@today">
                                                <div class="sf-field sf-field--site">
                                                    <span class="sf-icon" aria-hidden="true">
                                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                                            <path stroke-linecap="round" stroke-linejoin="round"
                                                                  d="M4 21V7.5A2.5 2.5 0 0 1 6.5 5h7A2.5 2.5 0 0 1 16 7.5V21" />
                                                            <path stroke-linecap="round" stroke-linejoin="round"
                                                                  d="M16 9h1.5A2.5 2.5 0 0 1 20 11.5V21M8 10h.01M12 10h.01M8 14h.01M12 14h.01M9 21v-3h2v3" />
                                                        </svg>
                                                    </span>
                                                    <div class="sf-control">
                                                        <label class="sf-label">Sede</label>
                                                        <select name="SiteId" class="sf-input" aria-label="Sede"
                                                                data-availability-site-select>
                                                            <option value="">Todas las sedes</option>
                                                            @foreach (var site in guestModel.Sites)
                                                            {
                                                                <option value="@site.Id">@site.Name</option>
                                                            }
                                                        </select>
                                                    </div>
                                                </div>
                                                <div class="sf-field sf-field--dates" data-date-range-anchor>
                                                    <span class="sf-icon" aria-hidden="true">
                                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                                            <path stroke-linecap="round" stroke-linejoin="round"
                                                                  d="M8 3v4M16 3v4M4.5 9.5h15M6.5 5h11A2.5 2.5 0 0 1 20 7.5v10A2.5 2.5 0 0 1 17.5 20h-11A2.5 2.5 0 0 1 4 17.5v-10A2.5 2.5 0 0 1 6.5 5Z" />
                                                        </svg>
                                                    </span>
                                                    <div class="sf-control">
                                                        <label class="sf-label">Fechas</label>
                                                        <button type="button" class="sf-date-trigger" data-date-range-trigger
                                                                aria-haspopup="dialog" aria-expanded="false">
                                                            <span data-date-label="checkin">Selecciona fechas</span>
                                                            <span class="sf-date-separator" data-date-separator aria-hidden="true"
                                                                  hidden>-</span>
                                                            <span data-date-label="checkout"></span>
                                                            <span class="custom-select-chevron" aria-hidden="true">
                                                                <svg viewBox="0 0 20 20" fill="currentColor">
                                                                    <path fill-rule="evenodd"
                                                                          d="M5.23 7.21a.75.75 0 0 1 1.06.02L10 11.168l3.71-3.938a.75.75 0 1 1 1.08 1.04l-4.25 4.5a.75.75 0 0 1-1.08 0l-4.25-4.5a.75.75 0 0 1 .02-1.06Z"
                                                                          clip-rule="evenodd" />
                                                                </svg>
                                                            </span>
                                                        </button>
                                                        <input type="hidden" name="CheckIn" value="@today" data-date-input="checkin" />
                                                        <input type="hidden" name="CheckOut" value="@tomorrow" data-date-input="checkout" />
                                                    </div>
                                                </div>
                                                <div class="sf-field sf-field--guests" data-guests-panel>
                                                    <span class="sf-icon" aria-hidden="true">
                                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                                            <path stroke-linecap="round" stroke-linejoin="round"
                                                                  d="M16 20v-1.5A3.5 3.5 0 0 0 12.5 15h-5A3.5 3.5 0 0 0 4 18.5V20M10 11a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7ZM20 20v-1a3 3 0 0 0-2.25-2.9M16.5 4.35a3 3 0 0 1 0 5.8" />
                                                        </svg>
                                                    </span>
                                                    <div class="sf-control">
                                                        <label class="sf-label">Huéspedes</label>
                                                        <button type="button" class="sf-guest-trigger" data-guests-trigger
                                                                aria-haspopup="dialog" aria-expanded="false">
                                                            <span class="sf-guest-summary" data-guests-summary>2 huéspedes</span>
                                                            <span class="custom-select-chevron" aria-hidden="true">
                                                                <svg viewBox="0 0 20 20" fill="currentColor">
                                                                    <path fill-rule="evenodd"
                                                                          d="M5.23 7.21a.75.75 0 0 1 1.06.02L10 11.168l3.71-3.938a.75.75 0 1 1 1.08 1.04l-4.25 4.5a.75.75 0 0 1-1.08 0l-4.25-4.5a.75.75 0 0 1 .02-1.06Z"
                                                                          clip-rule="evenodd" />
                                                                </svg>
                                                            </span>
                                                        </button>
                                                        <input type="hidden" name="Guests" min="1" max="20" step="1" value="2"
                                                               class="sf-guest-input" data-guests-input="adults" />
                                                    </div>
                                                </div>
                                                <button type="submit" class="sf-submit">Buscar</button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </section>

                            @if (upcomingReservations.Any())
                            {
                                <section class="py-12" data-home-upcoming-reservations>
                                    <div class="mx-auto max-w-[1280px] px-4 sm:px-6 lg:px-8">
                                        <div class="mb-6 flex items-center justify-between">
                                            <h3 class="font-display text-4xl text-foreground">Mis próximas reservas</h3>
                                            <a asp-controller="Reservations" asp-action="Index"
                                               class="compute-button-outline h-10 min-h-10 px-4 text-xs">Ver todas</a>
                                        </div>
                                        <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
                                            @foreach (var reservation in upcomingReservations)
                                            {
                                                var firstDetail = reservation.Details.FirstOrDefault();
                                                var siteName = string.IsNullOrWhiteSpace(firstDetail?.SiteName) ? "Sede por confirmar" :
                    firstDetail.SiteName;
                                                var accommodationName = string.IsNullOrWhiteSpace(firstDetail?.AccommodationName) ? "Alojamiento" :
                    firstDetail.AccommodationName;
                                                var nights = Math.Max(1, (reservation.CheckOut.Date - reservation.CheckIn.Date).Days);
                                                var statusColor = reservation.Status switch
                                                {
                                                    ReservationStatus.Pending => "bg-amber-50 text-amber-700",
                                                    ReservationStatus.Confirmed => "bg-blue-50 text-blue-700",
                                                    ReservationStatus.CheckedIn => "bg-green-50 text-green-700",
                                                    ReservationStatus.CheckedOut => "bg-gray-50 text-gray-700",
                                                    ReservationStatus.Cancelled => "bg-red-50 text-red-700",
                                                    _ => "bg-gray-50 text-gray-600"
                                                };
                                                <a asp-controller="Reservations" asp-action="Details" asp-route-id="@reservation.Id"
                                                   class="compute-card rounded-3xl p-6 hover-lift block transition">
                                                    <div class="flex items-start justify-between gap-4">
                                                        <div class="min-w-0">
                                                            <p class="font-display text-2xl leading-none text-foreground">@siteName</p>
                                                            <p class="mt-2 text-sm text-muted-foreground">@accommodationName</p>
                                                        </div>
                                                        <span
                                                        class="shrink-0 rounded-full px-3 py-1 text-xs font-medium @statusColor">@reservation.Status.ToSpanish()</span>
                                                    </div>
                                                    <p class="mt-5 text-sm text-muted-foreground">
                                                        @reservation.CheckIn.ToString("dd MMM", culture) - @reservation.CheckOut.ToString("dd MMM yyyy",
                                                        culture)
                                                    </p>
                                                    <p class="mt-1 text-sm text-muted-foreground">@nights noche@(nights != 1 ? "s" : "") ·
                                                        @reservation.TotalGuests huésped@(reservation.TotalGuests != 1 ? "es" : "")</p>
                                                        <div class="mt-5 flex items-end justify-between gap-4">
                                                            <p class="font-display text-3xl leading-none text-foreground">
                                                                $@reservation.TotalAmount.ToString("N0", culture)</p>
                                                                <span class="text-sm font-medium text-primary">Ver detalle</span>
                                                            </div>
                                                        </a>
                                                    }
                                                </div>
                                            </div>
                                        </section>
                                    }

                                    <section class="py-12" data-availability-surface>
                                        <div class="mx-auto max-w-[1280px] px-4 sm:px-6 lg:px-8">
                                            <div data-availability-content>
                                                <div class="mb-8">
                                                    <p class="font-mono text-xs uppercase tracking-[0.24em] text-muted-foreground">Destinos destacados
                                                    </p>
                                                    <h3 class="mt-2 font-display text-5xl leading-none text-foreground">Nuestros destinos</h3>
                                                    <p class="mt-3 max-w-2xl text-muted-foreground">Sedes recreativas y apartamentos del Fondo XYZ para
                                                        descanso, deporte y viajes familiares.</p>
                                                    </div>
                                                    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
                                                        @for (var index = 0; index < guestModel.Sites.Count; index++)
                                                        {
                                                            var site = guestModel.Sites[index];
                                                            var imageUrl = string.IsNullOrWhiteSpace(site.ImageUrl) ? null : Url.Content(site.ImageUrl);
                                                            var imageStyle = string.IsNullOrWhiteSpace(imageUrl) ? null : $"background-image: url('{imageUrl}')";
                                                            <button type="button" class="site-card group" data-site-card
                                                                    data-site-id="@site.Id">
                                                                <div class="site-card-image relative block w-full shrink-0 overflow-hidden" style="@imageStyle">
                                                                    @if (!string.IsNullOrWhiteSpace(imageUrl))
                                                                    {
                                                                        <img src="@imageUrl" asp-append-version="true" alt="@site.Name"
                                                                             class="site-card-image-media absolute inset-0 block h-full w-full object-cover"
                                                                             decoding="async" />
                                                                    }
                                                                    <div class="site-card-image-overlay"></div>
                                                                    <span class="site-card-badge">@site.City</span>
                                                                </div>
                                                                <div class="site-card-body">
                                                                    <h4 class="site-card-title">@site.Name</h4>
                                                                    <div class="site-card-stats">
                                                                        <span class="site-card-stat">
                                                                            <svg class="site-card-stat-icon" viewBox="0 0 24 24" fill="none"
                                                                                 stroke="currentColor" stroke-width="1.5">
                                                                                <path stroke-linecap="round" stroke-linejoin="round"
