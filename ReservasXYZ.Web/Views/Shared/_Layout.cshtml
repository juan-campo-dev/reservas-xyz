@using Microsoft.AspNetCore.Identity
@using ReservasXYZ.Domain.Entities
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Reservas XYZ</title>
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
    <partial name="_AppFonts" />
    <script>
            (() => {
                const currentPath = window.location.pathname.toLowerCase();
                const isAuthenticated = @(User.Identity?.IsAuthenticated == true ? "true" : "false");
                const isAdmin = @(User.IsInRole("Admin") ? "true" : "false");
                const isHomeRoute = currentPath === '/' || currentPath === '/home' || currentPath === '/home/index';

                if (isHomeRoute) {
                    document.documentElement.classList.add('nav-starts-over-hero');
                }

                if (isAuthenticated && !isAdmin && isHomeRoute) {
                    try {
                        const savedSearch = JSON.parse(sessionStorage.getItem('reservasxyz:availability-search') ?? 'null');
                        const hasSavedAvailabilitySearch = savedSearch
                            && savedSearch.checkIn
                            && savedSearch.checkOut
                            && Number(savedSearch.guests) > 0;

                        if (hasSavedAvailabilitySearch) {
                            document.documentElement.classList.add('availability-search-active', 'availability-search-restoring');
                        }
                    } catch {
                    }
                }

                if (!isAuthenticated && isHomeRoute) {
                    document.documentElement.classList.add('public-home-route');
                }

            })();
    </script>
    <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />
</head>

<body class="min-h-screen bg-background text-foreground noise-overlay">
    @{
        var routeController = ViewContext.RouteData.Values["controller"]?.ToString();
        var routeAction = ViewContext.RouteData.Values["action"]?.ToString();
        var isHomePage = string.Equals(routeController, "Home", StringComparison.OrdinalIgnoreCase)
            && (string.IsNullOrWhiteSpace(routeAction) || string.Equals(routeAction, "Index",
    StringComparison.OrdinalIgnoreCase));
    }

    @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Admin"))
    {
        <div class="admin-shell">
            <partial name="_AdminTopNav" />
            <div class="admin-main">
                <main class="admin-main__inner">
                    <partial name="_Notifications" />
                    @RenderBody()
                </main>
            </div>
        </div>
    }
    else if (User.Identity?.IsAuthenticated == true)
    {
        var currentUser = await UserManager.GetUserAsync(User);
        var fullName = $"{currentUser?.FirstName} {currentUser?.LastName}".Trim();
        var profileName = string.IsNullOrWhiteSpace(fullName) ? "Usuario" : fullName;
        var profileInitial = profileName[0].ToString().ToUpperInvariant();

        <div class="min-h-screen bg-background text-foreground">
                <header data-public-header class="public-header @(isHomePage ? "fixed top-0 left-0 right-0 z-50" : "public-header--flat")">
                    <nav data-public-nav
                         class="public-nav mx-auto max-w-[1280px] px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between relative">
                        <a asp-controller="Home" asp-action="Index" class="public-brand-link flex items-baseline gap-0.5 group"
                           data-clear-availability-search>
                            <span
                            class="public-brand-wordmark font-display text-2xl tracking-tight text-foreground">RESERVAS</span>
                            <span class="public-brand-dot">.</span>
                            <span class="public-brand-tag font-mono text-[10px] text-muted-foreground">XYZ</span>
                        </a>
                        <div class="hidden md:flex items-center gap-10 text-sm text-muted-foreground absolute left-1/2 -translate-x-1/2">
                            <a asp-controller="Home" asp-action="Index"
                               class="public-nav-link hover:text-foreground transition">Buscar disponibilidad</a>
                            <a asp-controller="Reservations" asp-action="Index"
                               class="public-nav-link hover:text-foreground transition">Mis reservas</a>
                        </div>
                        <div class="flex items-center gap-3">
                            <details class="profile-menu" data-profile-menu>
                                <summary class="profile-menu-trigger" aria-label="Abrir menu de perfil">
                                    <span class="profile-avatar">@profileInitial</span>
                                    <svg class="profile-chevron" viewBox="0 0 12 12" fill="none" stroke="currentColor"
                                         stroke-width="1.6" aria-hidden="true">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 4.5 6 7.5 9 4.5" />
                                    </svg>
                                </summary>
                                <div class="profile-menu-panel" role="menu">
                                    <div class="profile-menu-header">
                                        <span class="profile-menu-title">@profileName</span>
                                        <span class="profile-menu-subtitle">Usuario</span>
                                    </div>
                                    <a asp-controller="Home" asp-action="Index" class="profile-menu-item" role="menuitem">
                                        Buscar disponibilidad
                                    </a>
                                    <a asp-controller="Reservations" asp-action="Index" class="profile-menu-item"
                                       role="menuitem">
                                        Mis reservas
                                    </a>
                                    <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/" method="post"
                                          class="profile-menu-form">
                                        <button type="submit" class="profile-menu-item profile-menu-logout" role="menuitem">
                                            <svg class="profile-menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                                 stroke-width="1.6">
                                                <path stroke-linecap="round" stroke-linejoin="round"
                                                      d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15m3 0 3-3m0 0-3-3m3 3H9" />
                                            </svg>
                                            Salir
                                        </button>
                                    </form>
                                </div>
                            </details>
                        </div>
                    </nav>
                </header>
            <main>
                <partial name="_Notifications" />
                @RenderBody()
            </main>
        </div>
    }
    else
    {
        <div class="min-h-screen bg-background text-foreground">
            @if (isHomePage)
            {
                <header data-public-header class="public-header fixed top-0 left-0 right-0 z-50">
                    <nav data-public-nav
                         class="public-nav mx-auto max-w-[1280px] px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
                        <a asp-controller="Home" asp-action="Index" class="public-brand-link flex items-baseline gap-0.5 group"
                           data-clear-availability-search>
                            <span
                            class="public-brand-wordmark font-display text-2xl tracking-tight text-foreground">RESERVAS</span>
                            <span class="public-brand-dot">.</span>
                            <span class="public-brand-tag font-mono text-[10px] text-muted-foreground">XYZ</span>
                        </a>
                        <div class="hidden md:flex items-center gap-10 text-sm text-muted-foreground">
                            <a href="/#sedes" class="public-nav-link hover:text-foreground transition">Sedes</a>
                            <a href="/#disponibilidad"
                               class="public-nav-link hover:text-foreground transition">Disponibilidad</a>
                            <a href="/#tarifas" class="public-nav-link hover:text-foreground transition">Tarifas</a>
                            <a href="/#seguridad" class="public-nav-link hover:text-foreground transition">Regístrate</a>
                        </div>
                        <div class="flex items-center gap-3">
                            <a asp-area="Identity" asp-page="/Account/Login"
                               class="public-login-link hidden sm:inline-flex text-sm text-muted-foreground hover:text-foreground transition">
                                Iniciar sesión
                            </a>
                            <a asp-area="Identity" asp-page="/Account/Register" class="compute-button public-register-button">
                                Crear cuenta
                            </a>
                        </div>
                    </nav>
                </header>
            }
            <main>
                <partial name="_Notifications" />
                @RenderBody()
            </main>
        </div>
    }

    <script src="~/lib/jquery/dist/jquery.min.js" asp-append-version="true"></script>
    <script type="module" src="~/js/app.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
