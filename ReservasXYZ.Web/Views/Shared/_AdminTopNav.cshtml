@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var isDashboard = string.Equals(currentController, "Home", StringComparison.OrdinalIgnoreCase);
    var isReservations = string.Equals(currentController, "Reservations", StringComparison.OrdinalIgnoreCase);
    var isSites = string.Equals(currentController, "Sites", StringComparison.OrdinalIgnoreCase);
    var isAccommodations = string.Equals(currentController, "Accommodations", StringComparison.OrdinalIgnoreCase);
    var isRooms = string.Equals(currentController, "Rooms", StringComparison.OrdinalIgnoreCase);
    var isSeasons = string.Equals(currentController, "Seasons", StringComparison.OrdinalIgnoreCase);
    var isRates = string.Equals(currentController, "Rates", StringComparison.OrdinalIgnoreCase);

    string ActiveClass(bool active) => active
        ? "admin-header__link is-active"
        : "admin-header__link";
}

<header class="admin-header">
    <div class="admin-header__inner">
        <div class="admin-header__row">
            <div class="admin-header__left">
                <a asp-controller="Home" asp-action="Index" class="admin-header__brand">
                    <span class="admin-header__brand-main">RESERVAS</span>
                    <span class="admin-header__brand-dot">.</span>
                    <span class="admin-header__brand-tag">XYZ</span>
                </a>
            </div>

            <nav class="admin-header__nav" aria-label="Administracion">
                <a asp-controller="Home" asp-action="Index" class="@ActiveClass(isDashboard)">
                    <svg class="admin-header__link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="3" width="7" height="7" rx="2" />
                        <rect x="14" y="3" width="7" height="7" rx="2" />
                        <rect x="3" y="14" width="7" height="7" rx="2" />
                        <rect x="14" y="14" width="7" height="7" rx="2" />
                    </svg>
                    <span>Panel</span>
                </a>
                <a asp-controller="Reservations" asp-action="Index" class="@ActiveClass(isReservations)">
                    <svg class="admin-header__link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2" />
                        <rect x="9" y="3" width="6" height="4" rx="1" />
                        <path d="M9 14l2 2 4-4" />
                    </svg>
                    <span>Reservas</span>
                </a>
                @if (User.IsInRole("Admin"))
                {
                    <a asp-controller="Sites" asp-action="Index" class="@ActiveClass(isSites)">
                        <svg class="admin-header__link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M3 21h18" />
                            <path d="M5 21V7l8-4v18" />
                            <path d="M19 21V11l-6-4" />
                            <path d="M9 9h1" />
                            <path d="M9 13h1" />
                            <path d="M9 17h1" />
                        </svg>
                        <span>Sitios</span>
                    </a>
                    <a asp-controller="Accommodations" asp-action="Index" class="@ActiveClass(isAccommodations)">
                        <svg class="admin-header__link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M2 20v-8a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v8" />
                            <path d="M4 10V6a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v4" />
                            <path d="M2 20h20" />
                            <path d="M6 14h4" />
                            <path d="M14 14h4" />
                        </svg>
                        <span>Alojamientos</span>
                    </a>
                    <a asp-controller="Rooms" asp-action="Index" class="@ActiveClass(isRooms)">
                        <svg class="admin-header__link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M3 7v11a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V7" />
                            <path d="M21 7L12 2 3 7" />
                            <rect x="7" y="11" width="4" height="5" rx="0.5" />
                            <rect x="13" y="11" width="4" height="5" rx="0.5" />
                        </svg>
                        <span>Habitaciones</span>
                    </a>
                    <a asp-controller="Seasons" asp-action="Index" class="@ActiveClass(isSeasons)">
                        <svg class="admin-header__link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="4" width="18" height="18" rx="2" />
                            <path d="M16 2v4" />
                            <path d="M8 2v4" />
                            <path d="M3 10h18" />
                            <path d="M8 14h.01" />
                            <path d="M12 14h.01" />
                            <path d="M16 14h.01" />
                            <path d="M8 18h.01" />
                            <path d="M12 18h.01" />
                        </svg>
                        <span>Temporadas</span>
                    </a>
                    <a asp-controller="Rates" asp-action="Index" class="@ActiveClass(isRates)">
                        <svg class="admin-header__link-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="12" y1="1" x2="12" y2="23" />
                            <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
                        </svg>
                        <span>Tarifas</span>
                    </a>
                }
            </nav>

            <div class="admin-header__right">
                <div class="admin-header__divider"></div>
                <div class="admin-header__user">
                    <div class="admin-header__avatar">
                        @(User.Identity?.Name?.Substring(0, 1).ToUpperInvariant() ?? "A")
                    </div>
                    <span class="admin-header__username">@User.Identity?.Name</span>
                </div>
                <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/" method="post">
                    <button type="submit" class="admin-header__logout" title="Cerrar sesión">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"
                             stroke-linecap="round" stroke-linejoin="round">
                            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                            <polyline points="16 17 21 12 16 7" />
                            <line x1="21" y1="12" x2="9" y2="12" />
                        </svg>
                    </button>
                </form>
            </div>
        </div>

        <nav class="admin-header__mobile-nav" aria-label="Navegacion movil">
            <a asp-controller="Home" asp-action="Index"
               class="admin-header__mobile-tab @(isDashboard ? "is-active" : "")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"
                     stroke-linejoin="round">
                    <rect x="3" y="3" width="7" height="7" rx="1" />
                    <rect x="14" y="3" width="7" height="7" rx="1" />
                    <rect x="3" y="14" width="7" height="7" rx="1" />
                    <rect x="14" y="14" width="7" height="7" rx="1" />
                </svg>
                <span>Panel</span>
            </a>
            <a asp-controller="Reservations" asp-action="Index"
               class="admin-header__mobile-tab @(isReservations ? "is-active" : "")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"
                     stroke-linejoin="round">
                    <path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2" />
                    <rect x="9" y="3" width="6" height="4" rx="1" />
                    <path d="M9 14l2 2 4-4" />
                </svg>
                <span>Reservas</span>
            </a>
            @if (User.IsInRole("Admin"))
            {
                <a asp-controller="Sites" asp-action="Index" class="admin-header__mobile-tab @(isSites ? "is-active" : "")">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"
                         stroke-linejoin="round">
                        <path d="M3 21h18" />
                        <path d="M5 21V7l8-4v18" />
                        <path d="M19 21V11l-6-4" />
                    </svg>
                    <span>Sitios</span>
                </a>
                <a asp-controller="Accommodations" asp-action="Index"
                   class="admin-header__mobile-tab @(isAccommodations ? "is-active" : "")">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"
                         stroke-linejoin="round">
                        <path d="M2 20v-8a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v8" />
                        <path d="M4 10V6a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v4" />
                        <path d="M2 20h20" />
                    </svg>
                    <span>Alojam.</span>
                </a>
                <a asp-controller="Rooms" asp-action="Index" class="admin-header__mobile-tab @(isRooms ? "is-active" : "")">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"
                         stroke-linejoin="round">
                        <path d="M3 7v11a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V7" />
                        <path d="M21 7L12 2 3 7" />
                    </svg>
                    <span>Habita.</span>
                </a>
                <a asp-controller="Seasons" asp-action="Index"
                   class="admin-header__mobile-tab @(isSeasons ? "is-active" : "")">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"
                         stroke-linejoin="round">
                        <rect x="3" y="4" width="18" height="18" rx="2" />
                        <path d="M16 2v4" />
                        <path d="M8 2v4" />
                        <path d="M3 10h18" />
                    </svg>
                    <span>Tempos.</span>
                </a>
                <a asp-controller="Rates" asp-action="Index" class="admin-header__mobile-tab @(isRates ? "is-active" : "")">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"
                         stroke-linejoin="round">
                        <line x1="12" y1="1" x2="12" y2="23" />
                        <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
                    </svg>
                    <span>Tarifas</span>
                </a>
            }
        </nav>
    </div>
</header>
