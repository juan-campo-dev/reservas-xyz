@model IEnumerable<ReservasXYZ.Application.DTOs.SiteDto>
@{
    ViewData["Title"] = "Sitios";
    var sites = Model.ToList();
    var activeCount = sites.Count(s => s.IsActive);
    var inactiveCount = sites.Count - activeCount;
    var totalAccommodations = sites.Sum(s => s.AccommodationCount);
    var activePct = sites.Count > 0 ? (int)Math.Round(100.0 * activeCount / sites.Count) : 0;
    var inactivePct = 100 - activePct;
}

<div class="admin-page-header">
    <div>
        <h1 class="admin-page-header__title">Sitios</h1>
        <p class="admin-page-header__subtitle">Sedes recreativas y apartamentos del sistema</p>
    </div>
    <button type="button" class="admin-page-btn" onclick="openSiteModal()">
        <svg viewBox="0 0 20 20" fill="currentColor" style="width:1.125rem;height:1.125rem"><path d="M10.75 4.75a.75.75 0 0 0-1.5 0v4.5h-4.5a.75.75 0 0 0 0 1.5h4.5v4.5a.75.75 0 0 0 1.5 0v-4.5h4.5a.75.75 0 0 0 0-1.5h-4.5v-4.5Z"/></svg>
        Nuevo sitio
    </button>
</div>

@if (sites.Any())
{
    <section class="admin-module-stats" aria-label="Resumen">
        <div class="admin-module-stat admin-module-stat--blue">
            <div class="admin-module-stat__header">
                <span class="admin-module-stat__label">Total registros</span>
                <div class="admin-module-stat__indicator">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="admin-module-stat__icon" aria-hidden="true"><path d="M22 12h-2.48a2 2 0 0 0-1.93 1.46l-2.35 8.36a.25.25 0 0 1-.48 0L9.24 2.18a.25.25 0 0 0-.48 0l-2.35 8.36A2 2 0 0 1 4.49 12H2"/></svg>
                    <span class="admin-module-stat__pct">100%</span>
                </div>
            </div>
            <strong class="admin-module-stat__value">@sites.Count</strong>
            <div class="admin-module-stat__bar"><div class="admin-module-stat__bar-fill" style="width:100%"></div></div>
        </div>
        <div class="admin-module-stat admin-module-stat--green">
            <div class="admin-module-stat__header">
                <span class="admin-module-stat__label">Activos</span>
                <div class="admin-module-stat__indicator">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="admin-module-stat__icon" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
                    <span class="admin-module-stat__pct">@activePct%</span>
                </div>
            </div>
            <strong class="admin-module-stat__value">@activeCount</strong>
            <div class="admin-module-stat__bar"><div class="admin-module-stat__bar-fill" style="width:@(Math.Max(2,activePct))%"></div></div>
        </div>
        <div class="admin-module-stat admin-module-stat--orange">
            <div class="admin-module-stat__header">
                <span class="admin-module-stat__label">Inactivos</span>
                <div class="admin-module-stat__indicator">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="admin-module-stat__icon" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6"/><path d="m9 9 6 6"/></svg>
                    <span class="admin-module-stat__pct">@inactivePct%</span>
                </div>
            </div>
            <strong class="admin-module-stat__value">@inactiveCount</strong>
            <div class="admin-module-stat__bar"><div class="admin-module-stat__bar-fill" style="width:@(Math.Max(2,inactivePct))%"></div></div>
        </div>
        <div class="admin-module-stat admin-module-stat--purple">
            <div class="admin-module-stat__header">
                <span class="admin-module-stat__label">Alojamientos</span>
                <div class="admin-module-stat__indicator">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="admin-module-stat__icon" aria-hidden="true"><path d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.84Z"/><path d="m22 12.65-9.17 4.16a2 2 0 0 1-1.66 0L2 12.65"/><path d="m22 17.65-9.17 4.16a2 2 0 0 1-1.66 0L2 17.65"/></svg>
                    <span class="admin-module-stat__pct">acum.</span>
                </div>
            </div>
            <strong class="admin-module-stat__value">@totalAccommodations</strong>
            <div class="admin-module-stat__bar"><div class="admin-module-stat__bar-fill" style="width:100%"></div></div>
        </div>
    </section>

    <div class="admin-table-shell">
        <div class="admin-table-toolbar">
            <div class="admin-table-search">
                <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11ZM2 9a7 7 0 1 1 12.452 4.391l3.328 3.329a.75.75 0 1 1-1.06 1.06l-3.329-3.328A7 7 0 0 1 2 9Z" clip-rule="evenodd"/></svg>
                <input type="text" placeholder="Buscar sitios..." oninput="filterTable(this.value)" />
            </div>
        </div>
        <div style="overflow-x:auto">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th class="cell-hide-mobile">Ciudad</th>
                        <th class="cell-hide-mobile">País</th>
                        <th class="cell-hide-mobile">Alojamientos</th>
                        <th>Estado</th>
                        <th style="width:6rem">Acciones</th>
                    </tr>
                </thead>
                <tbody id="sitesTableBody">
                    @foreach (var site in sites)
                    {
                        <tr data-search="@site.Name @site.City @site.Country @site.Address">
                            <td>
                                <div style="font-weight:600">@site.Name</div>
                                <div style="font-size:.8rem;color:#64748b">@site.Address</div>
                            </td>
                            <td class="cell-hide-mobile">@site.City</td>
                            <td class="cell-hide-mobile">@site.Country</td>
                            <td class="cell-hide-mobile">@site.AccommodationCount</td>
                            <td>
                                <span class="admin-badge @(site.IsActive ? "admin-badge--active" : "admin-badge--inactive")">
                                    @(site.IsActive ? "Activo" : "Inactivo")
                                </span>
                            </td>
                            <td>
                                <div style="display:flex;gap:.35rem">
                                    <button type="button" class="admin-row-action" title="Editar" onclick="openSiteModal(@site.Id)">
                                        <svg viewBox="0 0 20 20" fill="currentColor"><path d="m5.433 13.917 1.262-3.155A4 4 0 0 1 7.58 9.42l6.92-6.918a2.121 2.121 0 0 1 3 3l-6.92 6.918c-.383.383-.84.685-1.343.886l-3.154 1.262a.5.5 0 0 1-.65-.65Z"/><path d="M3.5 5.75c0-.69.56-1.25 1.25-1.25H10A.75.75 0 0 0 10 3H4.75A2.75 2.75 0 0 0 2 5.75v9.5A2.75 2.75 0 0 0 4.75 18h9.5A2.75 2.75 0 0 0 17 15.25V10a.75.75 0 0 0-1.5 0v5.25c0 .69-.56 1.25-1.25 1.25h-9.5c-.69 0-1.25-.56-1.25-1.25v-9.5Z"/></svg>
                                    </button>
                                    <button type="button" class="admin-row-action admin-row-action--danger" title="Eliminar" onclick="deleteSite(@site.Id, '@site.Name.Replace("'", "\\'")' )">
                                        <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M8.75 1A2.75 2.75 0 0 0 6 3.75v.443c-.795.077-1.584.176-2.365.298a.75.75 0 1 0 .23 1.482l.149-.022.841 10.518A2.75 2.75 0 0 0 7.596 19h4.807a2.75 2.75 0 0 0 2.742-2.53l.841-10.52.149.023a.75.75 0 0 0 .23-1.482A41.03 41.03 0 0 0 14 4.193V3.75A2.75 2.75 0 0 0 11.25 1h-2.5ZM10 4c.84 0 1.673.025 2.5.075V3.75c0-.69-.56-1.25-1.25-1.25h-2.5c-.69 0-1.25.56-1.25 1.25v.325C8.327 4.025 9.16 4 10 4ZM8.58 7.72a.75.75 0 0 0-1.5.06l.3 7.5a.75.75 0 1 0 1.5-.06l-.3-7.5Zm4.34.06a.75.75 0 1 0-1.5-.06l-.3 7.5a.75.75 0 1 0 1.5.06l.3-7.5Z" clip-rule="evenodd"/></svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="admin-table-footer">
            <span>@sites.Count registro(s)</span>
        </div>
    </div>
}
else
{
    <div class="admin-table-shell">
        <div class="admin-table-empty">
            <p style="font-weight:600;margin-bottom:.25rem">No hay sitios registrados</p>
            <p style="color:#64748b;font-size:.875rem">Crea el primer sitio para comenzar a gestionar alojamientos.</p>
        </div>
    </div>
}

@section Scripts {
<script>
function filterTable(q) {
    const rows = document.querySelectorAll('#sitesTableBody tr');
    const term = q.toLowerCase();
    rows.forEach(r => { r.style.display = r.dataset.search.toLowerCase().includes(term) ? '' : 'none'; });
}

async function openSiteModal(id) {
    const url = id ? `/Sites/Edit/${id}` : '/Sites/Create';
    const res = await fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
    if (!res.ok) return;
    const html = await res.text();
    window.__adminModal.open(html, { wide: false });
    const form = window.__adminModal.panel.querySelector('form');
    if (form) {
        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            const fd = new FormData(form);
            const r = await fetch(form.action, { method: 'POST', body: fd, headers: { 'X-Requested-With': 'XMLHttpRequest' } });
            if (r.ok) { window.__adminModal.close(); location.reload(); }
            else {
                try { const d = await r.json(); alert(d.errors?.join('\n') || 'Error'); } catch { alert('Error al guardar'); }
            }
        });
    }
}

async function deleteSite(id, name) {
    const ok = await window.__AdminConfirm.show({ title: '¿Eliminar sitio?', description: `Se eliminará "${name}" permanentemente.`, variant: 'danger', confirmLabel: 'Eliminar' });
    if (!ok) return;
    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value
        || document.querySelector('meta[name="csrf-token"]')?.content || '';
    const fd = new FormData();
    fd.append('__RequestVerificationToken', token);
    const r = await fetch(`/Sites/Delete/${id}`, { method: 'POST', body: fd, headers: { 'X-Requested-With': 'XMLHttpRequest' } });
    if (r.ok) location.reload();
}
</script>
<form id="__tokenForm" method="post" style="display:none">@Html.AntiForgeryToken()</form>
}
