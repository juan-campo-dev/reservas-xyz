@model IEnumerable<ReservationDto>
@{
    var isAdmin = User.IsInRole("Admin");
    ViewData["Title"] = isAdmin ? "Reservas" : "Mis reservas";
    var culture = CultureInfo.GetCultureInfo("es-CO");
    var reservations = Model.OrderByDescending(reservation => reservation.CheckIn).ToList();
    var activeCount = reservations.Count(r => r.Status is ReservationStatus.Pending or ReservationStatus.Confirmed or ReservationStatus.CheckedIn);
    var pendingCount = reservations.Count(r => r.Status == ReservationStatus.Pending);
    var totalRooms = reservations.Sum(r => r.Details.Count);
    var cancelledCount = reservations.Count(r => r.Status == ReservationStatus.Cancelled);
    var activePct = reservations.Count > 0 ? (int)Math.Round(100.0 * activeCount / reservations.Count) : 0;
    var pendingPct = reservations.Count > 0 ? (int)Math.Round(100.0 * pendingCount / reservations.Count) : 0;
    var cancelledPct = reservations.Count > 0 ? (int)Math.Round(100.0 * cancelledCount / reservations.Count) : 0;

    string StatusBadgeClass(ReservationStatus s) => s switch
    {
        ReservationStatus.Pending => "reservation-status-badge--pending",
        ReservationStatus.Confirmed => "reservation-status-badge--confirmed",
        ReservationStatus.CheckedIn => "reservation-status-badge--checked-in",
        ReservationStatus.CheckedOut => "reservation-status-badge--checked-out",
        ReservationStatus.Cancelled => "reservation-status-badge--cancelled",
        _ => ""
    };
}

@if (isAdmin)
{
    <div class="admin-page-header">
        <div>
            <h1 class="admin-page-header__title">@ViewData["Title"]</h1>
            <p class="admin-page-header__subtitle">Seguimiento de solicitudes, estados y comprobantes</p>
        </div>
    </div>

    if (reservations.Any())
    {
        <section class="admin-module-stats" aria-label="Resumen de reservas">
            <div class="admin-module-stat admin-module-stat--blue">
                <div class="admin-module-stat__header">
                    <span class="admin-module-stat__label">Total registros</span>
                    <div class="admin-module-stat__indicator">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="admin-module-stat__icon" aria-hidden="true"><path d="M22 12h-2.48a2 2 0 0 0-1.93 1.46l-2.35 8.36a.25.25 0 0 1-.48 0L9.24 2.18a.25.25 0 0 0-.48 0l-2.35 8.36A2 2 0 0 1 4.49 12H2"/></svg>
                        <span class="admin-module-stat__pct">100%</span>
                    </div>
                </div>
                <strong class="admin-module-stat__value">@reservations.Count</strong>
                <div class="admin-module-stat__bar"><div class="admin-module-stat__bar-fill" style="width:100%"></div></div>
            </div>
            <div class="admin-module-stat admin-module-stat--green">
                <div class="admin-module-stat__header">
                    <span class="admin-module-stat__label">Activas</span>
                    <div class="admin-module-stat__indicator">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="admin-module-stat__icon" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
                        <span class="admin-module-stat__pct">@activePct%</span>
                    </div>
                </div>
                <strong class="admin-module-stat__value">@activeCount</strong>
                <div class="admin-module-stat__bar"><div class="admin-module-stat__bar-fill" style="width:@(Math.Max(2,activePct))%"></div></div>
            </div>
            <div class="admin-module-stat admin-module-stat--yellow">
                <div class="admin-module-stat__header">
                    <span class="admin-module-stat__label">Pendientes</span>
                    <div class="admin-module-stat__indicator">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="admin-module-stat__icon" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                        <span class="admin-module-stat__pct">@pendingPct%</span>
                    </div>
                </div>
                <strong class="admin-module-stat__value">@pendingCount</strong>
                <div class="admin-module-stat__bar"><div class="admin-module-stat__bar-fill" style="width:@(Math.Max(2,pendingPct))%"></div></div>
            </div>
            <div class="admin-module-stat admin-module-stat--orange">
                <div class="admin-module-stat__header">
                    <span class="admin-module-stat__label">Canceladas</span>
                    <div class="admin-module-stat__indicator">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="admin-module-stat__icon" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6"/><path d="m9 9 6 6"/></svg>
                        <span class="admin-module-stat__pct">@cancelledPct%</span>
                    </div>
                </div>
                <strong class="admin-module-stat__value">@cancelledCount</strong>
                <div class="admin-module-stat__bar"><div class="admin-module-stat__bar-fill" style="width:@(Math.Max(2,cancelledPct))%"></div></div>
            </div>
        </section>

        <div class="admin-table-shell">
            <div class="admin-table-toolbar">
                <div class="admin-table-search">
                    <svg viewBox="0 0 20 20" fill="currentColor" class="admin-table-search__icon"><path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11ZM2 9a7 7 0 1 1 12.452 4.391l3.328 3.329a.75.75 0 1 1-1.06 1.06l-3.329-3.328A7 7 0 0 1 2 9Z" clip-rule="evenodd"/></svg>
                    <input type="text" class="admin-table-search__input" placeholder="Buscar reservas..." oninput="filterTable(this.value)" />
                </div>
            </div>
            <div style="overflow-x:auto">
                <table class="admin-table">
                    <thead>
                        <tr>
                            <th>Huésped</th>
                            <th>Sede</th>
                            <th>Fechas</th>
                            <th class="cell-hide-mobile">Habitaciones</th>
                            <th>Total</th>
                            <th>Estado</th>
                            <th style="width:5rem">Acciones</th>
                        </tr>
                    </thead>
                    <tbody id="tableBody">
                        @foreach (var r in reservations)
                        {
                            var details = r.Details.ToList();
                            var siteNames = details.Select(d => d.SiteName).Where(n => !string.IsNullOrWhiteSpace(n)).Distinct().ToList();
                            var siteName = siteNames.Count == 1 ? siteNames[0] : (siteNames.Any() ? "Varias sedes" : "—");
                            var nights = Math.Max(1, (r.CheckOut.Date - r.CheckIn.Date).Days);
                            var roomLabel = details.Count == 1 ? details[0].RoomNumber : $"{details.Count} hab.";

                            <tr data-search="@r.GuestName @siteName @r.Status.ToSpanish() @r.Id">
                                <td>
                                    <div style="font-weight:600">@r.GuestName</div>
                                    <div style="font-size:.75rem;color:var(--muted-foreground)">@r.GuestEmail</div>
                                </td>
                                <td style="font-weight:600">@siteName</td>
                                <td>
                                    <div style="font-size:.8rem">@r.CheckIn.ToString("dd MMM", culture) — @r.CheckOut.ToString("dd MMM yy", culture)</div>
                                    <div style="font-size:.72rem;color:var(--muted-foreground)">@nights noche@(nights != 1 ? "s" : "")</div>
                                </td>
                                <td class="cell-hide-mobile">@roomLabel</td>
                                <td style="font-weight:600">$@r.TotalAmount.ToString("N0", culture)</td>
                                <td>
                                    <span class="reservation-status-badge @StatusBadgeClass(r.Status)">@r.Status.ToSpanish()</span>
                                </td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@r.Id" class="admin-row-action" title="Ver detalle">
                                        <svg viewBox="0 0 20 20" fill="currentColor"><path d="M10 12.5a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5Z"/><path fill-rule="evenodd" d="M.664 10.59a1.651 1.651 0 0 1 0-1.186A10.004 10.004 0 0 1 10 3c4.257 0 7.893 2.66 9.336 6.41.147.381.146.804 0 1.186A10.004 10.004 0 0 1 10 17c-4.257 0-7.893-2.66-9.336-6.41ZM14 10a4 4 0 1 1-8 0 4 4 0 0 1 8 0Z" clip-rule="evenodd"/></svg>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="admin-table-footer">
                <span>@reservations.Count reserva@(reservations.Count != 1 ? "s" : "") · @totalRooms habitación@(totalRooms != 1 ? "es" : "")</span>
            </div>
        </div>
    }
    else
    {
        <div class="admin-table-shell">
            <div class="admin-table-empty">
                <p style="font-weight:600;margin-bottom:.25rem">No hay reservas registradas</p>
                <p style="color:#64748b;font-size:.875rem">Las reservas aparecerán aquí cuando los huéspedes confirmen solicitudes.</p>
            </div>
        </div>
    }
}
else
{
    <div class="mx-auto max-w-[1280px] px-4 sm:px-6 lg:px-8 py-10">
        <div class="flex flex-wrap items-start justify-between gap-4">
            <div>
                <p class="font-mono text-xs uppercase tracking-[0.24em] text-muted-foreground">Portal de reservas</p>
                <h1 class="mt-2 font-display text-4xl tracking-tight text-foreground">Mis reservas</h1>
                <p class="mt-2 text-muted-foreground">Revisa tus solicitudes, fechas y estados</p>
            </div>
            <a asp-controller="Home" asp-action="Index"
               class="compute-button h-10 min-h-10 px-4 text-xs inline-flex items-center gap-2">
                <svg viewBox="0 0 20 20" fill="currentColor" class="size-4"><path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11ZM2 9a7 7 0 1 1 12.452 4.391l3.328 3.329a.75.75 0 1 1-1.06 1.06l-3.329-3.328A7 7 0 0 1 2 9Z" clip-rule="evenodd"/></svg>
                Buscar disponibilidad
            </a>
        </div>

        @if (reservations.Any())
        {
            <div class="mt-8 grid grid-cols-2 gap-4 lg:grid-cols-4">
                <div class="compute-card rounded-2xl p-5">
                    <div class="flex items-center justify-between">
                        <span class="text-sm text-muted-foreground">Total</span>
                        <span class="font-mono text-xs text-muted-foreground">100%</span>
                    </div>
                    <p class="mt-3 font-display text-3xl leading-none text-foreground">@reservations.Count</p>
                    <div class="mt-3 h-0.5 rounded-full" style="background:color-mix(in oklch, var(--foreground) 8%, transparent)">
                        <div class="h-full rounded-full bg-blue-500" style="width:100%"></div>
                    </div>
                </div>
                <div class="compute-card rounded-2xl p-5">
                    <div class="flex items-center justify-between">
                        <span class="text-sm text-muted-foreground">Activas</span>
                        <span class="font-mono text-xs text-muted-foreground">@activePct%</span>
                    </div>
                    <p class="mt-3 font-display text-3xl leading-none text-foreground">@activeCount</p>
                    <div class="mt-3 h-0.5 rounded-full" style="background:color-mix(in oklch, var(--foreground) 8%, transparent)">
                        <div class="h-full rounded-full bg-green-500" style="width:@(Math.Max(2,activePct))%"></div>
                    </div>
                </div>
                <div class="compute-card rounded-2xl p-5">
                    <div class="flex items-center justify-between">
                        <span class="text-sm text-muted-foreground">Pendientes</span>
                        <span class="font-mono text-xs text-muted-foreground">@pendingPct%</span>
                    </div>
                    <p class="mt-3 font-display text-3xl leading-none text-foreground">@pendingCount</p>
                    <div class="mt-3 h-0.5 rounded-full" style="background:color-mix(in oklch, var(--foreground) 8%, transparent)">
                        <div class="h-full rounded-full bg-amber-500" style="width:@(Math.Max(2,pendingPct))%"></div>
                    </div>
                </div>
                <div class="compute-card rounded-2xl p-5">
                    <div class="flex items-center justify-between">
                        <span class="text-sm text-muted-foreground">Canceladas</span>
                        <span class="font-mono text-xs text-muted-foreground">@cancelledPct%</span>
                    </div>
                    <p class="mt-3 font-display text-3xl leading-none text-foreground">@cancelledCount</p>
                    <div class="mt-3 h-0.5 rounded-full" style="background:color-mix(in oklch, var(--foreground) 8%, transparent)">
                        <div class="h-full rounded-full bg-red-500" style="width:@(Math.Max(2,cancelledPct))%"></div>
                    </div>
                </div>
            </div>

            <div class="mt-8 relative">
                <svg viewBox="0 0 20 20" fill="currentColor" class="pointer-events-none absolute left-4 top-1/2 size-5 -translate-y-1/2 text-muted-foreground z-10"><path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11ZM2 9a7 7 0 1 1 12.452 4.391l3.328 3.329a.75.75 0 1 1-1.06 1.06l-3.329-3.328A7 7 0 0 1 2 9Z" clip-rule="evenodd"/></svg>
                <input type="text" placeholder="Buscar reservas por sede, alojamiento o estado..." oninput="filterCards(this.value)"
                       class="compute-input text-base" style="min-height:3.25rem;border-radius:1rem;padding-left:3rem;background:#ffffff;" />
            </div>

            <div class="mt-6 grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3" id="reservationCards">
                @foreach (var r in reservations)
                {
                    var details = r.Details.ToList();
                    var siteNames = details.Select(d => d.SiteName).Where(n => !string.IsNullOrWhiteSpace(n)).Distinct().ToList();
                    var siteName = siteNames.Count == 1 ? siteNames[0] : (siteNames.Any() ? "Varias sedes" : "—");
                    var nights = Math.Max(1, (r.CheckOut.Date - r.CheckIn.Date).Days);
                    var roomLabel = details.Count == 1 ? details[0].AccommodationName : $"{details.Count} habitaciones";

                    <a asp-action="Details" asp-route-id="@r.Id"
                       class="compute-card rounded-3xl p-6 hover-lift block transition"
                       data-search="@r.GuestName @siteName @r.Status.ToSpanish() @r.Id">
                        <div class="flex items-start justify-between gap-3">
                            <div class="min-w-0">
                                <p class="font-display text-2xl leading-none text-foreground">@siteName</p>
                                <p class="mt-2 text-sm text-muted-foreground">@roomLabel</p>
                            </div>
                            <span class="reservation-status-badge @StatusBadgeClass(r.Status) shrink-0">@r.Status.ToSpanish()</span>
                        </div>
                        <p class="mt-5 text-sm text-muted-foreground">
                            @r.CheckIn.ToString("dd MMM", culture) — @r.CheckOut.ToString("dd MMM yy", culture)
                        </p>
                        <p class="mt-1 text-sm text-muted-foreground">@nights noche@(nights != 1 ? "s" : "") · @r.TotalGuests huésped@(r.TotalGuests != 1 ? "es" : "")</p>
                        <div class="mt-5 flex items-end justify-between gap-4">
                            <p class="font-display text-3xl leading-none text-foreground">$@r.TotalAmount.ToString("N0", culture)</p>
                            <span class="text-sm font-medium text-primary">Ver detalle</span>
                        </div>
                    </a>
                }
            </div>

            <p class="mt-6 text-sm text-muted-foreground">
                @reservations.Count reserva@(reservations.Count != 1 ? "s" : "") · @totalRooms habitación@(totalRooms != 1 ? "es" : "")
            </p>
        }
        else
        {
            <div class="mt-16 text-center">
                <div class="mx-auto flex size-16 items-center justify-center rounded-full" style="background:color-mix(in oklch, var(--foreground) 5%, transparent)">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="size-7 text-muted-foreground">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25Z" />
                    </svg>
                </div>
                <p class="mt-5 font-display text-2xl text-foreground">No tienes reservas todavía</p>
                <p class="mt-2 max-w-md mx-auto text-muted-foreground">Cuando confirmes una solicitud, aparecerá aquí con fechas, estado y total.</p>
                <a asp-controller="Home" asp-action="Index"
                   class="compute-button mt-6 inline-flex items-center gap-2 text-sm">
                    Buscar disponibilidad
                </a>
            </div>
        }
    </div>
}

@section Scripts {
<script>
function filterTable(q) {
    const rows = document.querySelectorAll('#tableBody tr');
    const term = q.toLowerCase();
    rows.forEach(r => { r.style.display = r.dataset.search.toLowerCase().includes(term) ? '' : 'none'; });
}
function filterCards(q) {
    const cards = document.querySelectorAll('#reservationCards > a');
    const term = q.toLowerCase();
    cards.forEach(c => { c.style.display = c.dataset.search.toLowerCase().includes(term) ? '' : 'none'; });
}
</script>
}
